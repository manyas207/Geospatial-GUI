OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=60
OLLAMA_ENABLED=true

# Required for Heat & Equity — Census ACS tract demographics (free)
# https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=your_census_api_key_here

# Optional — set true to also render matplotlib PNG previews (MapLibre is default)
# CITY_LAYERS_RENDER_PNG=false

# Geocoding uses Census Geocoder + OpenStreetMap Nominatim fallback (no key required).

# Chat rate limits (per client IP, in-memory — resets on server restart)
CHAT_RATE_LIMIT_MAX=15
CHAT_RATE_LIMIT_WINDOW=60
CHAT_MAX_QUESTION_LENGTH=2000

# Optional — OBIA segment count for web runs (default 50000; lower = faster, coarser)
# OBIA_N_SEGMENTS=50000
# Optional — minimum purity for a labeled segment (0 = accept any pixel/point sample)
# OBIA_MIN_CLASS_FRACTION=0
